# Vercel AI Gateway — auto-detected by the AI SDK
AI_GATEWAY_API_KEY=

# Sendblue credentials (auto-detected by chat-adapter-sendblue)
SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=
SENDBLUE_FROM_NUMBER=
SENDBLUE_WEBHOOK_SECRET=

# Redis URL for the Chat SDK state adapter — REQUIRED in production (serverless).
# Without it, the bot falls back to in-memory state, which loses subscriptions
# and breaks distributed locking across function invocations. On Vercel,
# install the Upstash Redis Marketplace integration and KV_URL is auto-set.
# Leave empty in dev — memory state is fine for a single long-running process.
REDIS_URL=
